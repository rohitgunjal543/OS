#include <stdio.h>
#include <fcntl.h>
#include <unistd.h>
#include <string.h>

int main() {
    int fd;
    char data[] = "Linux System Calls Example\n";

    fd = open("sample.txt", O_CREAT | O_WRONLY, 0644);
    write(fd, data, strlen(data));
    close(fd);

    printf("Process ID: %d\n", getpid());
    printf("User ID: %d\n", getuid());
    printf("Group ID: %d\n", getgid());

    return 0;
}
